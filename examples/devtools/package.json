    "@json-render/devtools-react": "workspace:*",
    "@json-render/react": "workspace:*",
    "ai": "^6.0.168",
    "next": "^16.2.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@internal/eslint-config": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "typescript": "^5.7.2"
